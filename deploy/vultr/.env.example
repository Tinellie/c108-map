# Domain used for HTTPS certificate and public access.
DOMAIN=example.com
ACME_EMAIL=admin@example.com

# MySQL bootstrap values for the db container.
MYSQL_ROOT_PASSWORD=change-this-root-password
MYSQL_DATABASE=cm_circle
MYSQL_USER=cm_app
MYSQL_PASSWORD=change-this-db-password

# Keep this empty when frontend and API share the same domain via reverse proxy.
VITE_API_BASE_URL=
