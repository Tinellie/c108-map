# Database (must match deploy/vultr/.env)
MYSQL_HOST=db
MYSQL_PORT=3306
MYSQL_USER=cm_app
MYSQL_PASSWORD=change-this-db-password
MYSQL_DATABASE=cm_circle
MYSQL_CONNECTION_LIMIT=10

# API runtime inside container
API_HOST=0.0.0.0
API_PORT=3000
API_CORS_ORIGIN=https://example.com
API_PUBLIC_BASE_URL=https://example.com

# Auth
AUTH_SESSION_COOKIE_NAME=ctk_session
AUTH_SESSION_TTL_HOURS=8
AUTH_SESSION_SECRET=change-this-long-random-secret
AUTH_COOKIE_SECURE=true
AUTH_BOOTSTRAP_USERNAME=admin
AUTH_BOOTSTRAP_PASSWORD=change-this-admin-password

# Puppeteer and map extraction
PUPPETEER_HEADLESS=true
PUPPETEER_NAVIGATION_TIMEOUT_MS=45000
CHROME_EXECUTABLE_PATH=/usr/bin/chromium

# Storage-related paths
IMAGE_DOWNLOAD_DIR=storage/images/circle
MAP_PDF_PATH=storage/map.pdf
MAP_EXTRACTION_OUTPUT_DIR=storage/map_extracted
MAP_EXTRACTION_DPI=200
