{
  "name": "puppeteer-mysql-scraper-framework",
  "version": "0.1.0",
  "description": "Rough framework for scraping with Puppeteer and organizing data in MySQL",
  "type": "module",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "start:dev": "node --watch src/index.js",
    "api": "node src/api/server.js",
    "api:dev": "node --watch src/api/server.js",
    "map:extract": "python src/tools/extract_map_booths.py"
  },
  "dependencies": {
    "chalk": "^5.6.0",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^5.1.0",
    "mysql2": "^3.14.2",
    "pdfjs-dist": "^6.1.200",
    "puppeteer": "^24.11.2"
  }
}
