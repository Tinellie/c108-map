MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=159264837
MYSQL_DATABASE=cm_circle

# Optional runtime config
PUPPETEER_HEADLESS=true
PUPPETEER_NAVIGATION_TIMEOUT_MS=45000

# Use your local Chrome binary (optional)
CHROME_EXECUTABLE_PATH=C:\Program Files\Google\Chrome\Application\chrome.exe

# Use your existing Chrome user data dir/profile (optional)
# Note: close normal Chrome before running if you use this mode.
# CHROME_USER_DATA_DIR=C:\Users\YourName\AppData\Local\Google\Chrome\User Data
# CHROME_PROFILE_DIRECTORY=Default

# Alternative: connect to a running Chrome with remote debugging (optional)
# Example: ws://127.0.0.1:9222/devtools/browser/<id>
# PUPPETEER_BROWSER_WS_ENDPOINT=

# Image download folder (optional)
# Default: storage/images/circle
# IMAGE_DOWNLOAD_DIR=storage/images/circle

# API server config
API_HOST=127.0.0.1
API_PORT=3000
# Use * for all origins, or comma-separated origins like http://localhost:5173
API_CORS_ORIGIN=*
